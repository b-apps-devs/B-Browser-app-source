{
  "name": "b-browser",
  "version": "1.0.0",
  "description": "Modern Browser",
  "author": "DevBlzAlphaK1dXD",
  "main": "main.js",
  "license": "MIT",

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win",
    "portable": "electron-builder --win portable"
  },

  "build": {
    "appId": "com.devblzalpha.bbrowser",
    "productName": "B-Browser",
    "artifactName": "${productName}-${version}.${ext}",

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*",
      "!*.log"
    ],

    "extraResources": [],

    "asar": true,

    "compression": "maximum",

    "copyright": "© 2026 DevBlzAlphaK1dXD",

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],

      "icon": "build/icon.ico"
    },

    "portable": {
      "artifactName": "B-Browser-Portable.exe"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "B-Browser",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },

  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12"
  }
}
